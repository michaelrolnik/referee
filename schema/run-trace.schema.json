{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelrolnik/referee/schema/run-trace.schema.json",
  "title": "referee run trace",
  "description": "One line of a --explain run trace. The file is newline-delimited JSON: a header, then the trace's signals, then one line per requirement. Validate line by line; a whole file is not a single document by design, so that a writer never holds the run in memory and a reader can stop early.",
  "oneOf": [
    {
      "$ref": "#/$defs/header"
    },
    {
      "$ref": "#/$defs/signal"
    },
    {
      "$ref": "#/$defs/requirement"
    }
  ],
  "$defs": {
    "header": {
      "type": "object",
      "required": [
        "kind",
        "version",
        "specification",
        "trace",
        "states"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "header"
        },
        "version": {
          "type": "integer",
          "const": 1
        },
        "specification": {
          "$ref": "#/$defs/artifact"
        },
        "trace": {
          "type": "object",
          "required": [
            "path",
            "states"
          ],
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string"
            },
            "states": {
              "type": "integer",
              "minimum": 0
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            }
          }
        },
        "libraries": {
          "description": "Objects loaded for external functions. Present so a verdict that depended on a binary says which one -- without it the run is not reproducible.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "states": {
          "description": "Written once. Every values array in the file is parallel to states.time, which is why this is not one line per state.",
          "type": "object",
          "required": [
            "time"
          ],
          "additionalProperties": false,
          "properties": {
            "time": {
              "type": "array",
              "items": {
                "type": "integer"
              },
              "description": "Timestamps in the trace's own unit, non-decreasing."
            }
          }
        }
      }
    },
    "requirement": {
      "type": "object",
      "required": [
        "kind",
        "where",
        "verdict",
        "vacuous",
        "scope",
        "rows"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "requirement"
        },
        "name": {
          "description": "The @name, absent when the requirement is unnamed.",
          "type": "string"
        },
        "where": {
          "description": "Source label, always present: it is the identity when there is no name.",
          "type": "string",
          "pattern": "^(.+:)?[0-9]+:[0-9]+ \\.\\. [0-9]+:[0-9]+$"
        },
        "verdict": {
          "enum": [
            "pass",
            "fail"
          ]
        },
        "vacuous": {
          "description": "True when the requirement held for a reason unrelated to the system behaving. May be true together with verdict=pass -- that combination is the point.",
          "type": "boolean"
        },
        "vacuity": {
          "$ref": "#/$defs/vacuity"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "witness": {
          "description": "State index that settled the verdict, or null when nothing did.",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/row"
          }
        }
      },
      "allOf": [
        {
          "description": "A vacuity reason is required exactly when vacuous is true.",
          "if": {
            "properties": {
              "vacuous": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "vacuity"
            ]
          },
          "else": {
            "not": {
              "required": [
                "vacuity"
              ]
            }
          }
        }
      ]
    },
    "scope": {
      "type": "object",
      "required": [
        "kind",
        "active"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "description": "bare is a requirement written without a scope, and so evaluated only at the first state.",
          "enum": [
            "globally",
            "while",
            "between",
            "after_until",
            "bare"
          ]
        },
        "active": {
          "description": "Half-open [start, end) state-index pairs where the scope was open. An empty array is a scope that never opened -- the picture of vacuity, and why a reader needs to compute nothing.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/interval"
          }
        }
      }
    },
    "row": {
      "type": "object",
      "required": [
        "id",
        "label",
        "kind",
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "description": "Source text, for a human.",
          "type": "string"
        },
        "where": {
          "type": "string"
        },
        "kind": {
          "description": "How the value must be drawn. state is a fact about that state. temporal is a claim about the suffix (or prefix) from it, and carries witnesses so it can be drawn as a span rather than a cell -- drawn as a cell it reads identically to a state formula, which is the one thing a viewer must not get wrong. window is an accumulator, and carries the window it summarised.",
          "enum": [
            "state",
            "temporal",
            "window"
          ]
        },
        "type": {
          "$ref": "#/$defs/valueType"
        },
        "values": {
          "$ref": "#/$defs/values"
        },
        "witnesses": {
          "description": "temporal rows only. witnesses[i] is the state that settled values[i], or null when nothing did -- which for a strong operator is itself why it is false.",
          "type": "array",
          "items": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          }
        },
        "windows": {
          "description": "window rows only. The [lo, hi) state range each value summarised.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/interval"
          }
        },
        "ref": {
          "description": "The id of a signal line, when this row is a signal the requirement reads. Carries no values of its own -- exactly one of ref or values is present.",
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "temporal"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "witnesses"
            ]
          },
          "else": {
            "not": {
              "required": [
                "witnesses"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "window"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "windows"
            ]
          },
          "else": {
            "not": {
              "required": [
                "windows"
              ]
            }
          }
        },
        {
          "description": "A row either references a signal or carries its own values, never both and never neither.",
          "oneOf": [
            {
              "required": [
                "ref"
              ],
              "not": {
                "required": [
                  "values"
                ]
              }
            },
            {
              "required": [
                "values"
              ],
              "not": {
                "required": [
                  "ref"
                ]
              }
            }
          ]
        }
      ]
    },
    "vacuity": {
      "type": "object",
      "required": [
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "reason": {
          "description": "Distinguished because the fixes differ.",
          "enum": [
            "scope_never_opened",
            "antecedent_never_true",
            "evaluated_once",
            "quantifier_empty"
          ]
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "interval": {
      "description": "Half-open [start, end) over state indices.",
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "artifact": {
      "type": "object",
      "required": [
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "signal": {
      "description": "One declared signal of the trace, written once. Requirement rows reference these by id rather than repeating them: a signal read by twenty requirements would otherwise appear twenty times. It also means a viewer can draw the trace itself, and signals a requirement never mentions -- which is most of why a timing diagram is worth looking at, since the correlation you did not predict is the one you needed.",
      "type": "object",
      "required": [
        "kind",
        "id",
        "name",
        "type",
        "values"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "signal"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "description": "As declared, e.g. `pkt[0].flags`.",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/valueType"
        },
        "computed": {
          "description": "True for `data x = expr`, which is a property of the specification rather than of the recording.",
          "type": "boolean"
        },
        "values": {
          "$ref": "#/$defs/values"
        }
      }
    },
    "valueType": {
      "enum": [
        "boolean",
        "byte",
        "integer",
        "number",
        "string",
        "enum"
      ]
    },
    "values": {
      "description": "Parallel to header.states.time. null means not evaluated here -- outside a scope, or short-circuited -- and is not the same as false. Conflating them is how a vacuous requirement comes to look satisfied.",
      "type": "array",
      "items": {
        "type": [
          "boolean",
          "integer",
          "number",
          "string",
          "null"
        ]
      }
    }
  }
}

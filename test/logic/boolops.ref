# The logical operators and their word aliases. `&&`/`and`, `||`/`or`,
# `^^`/`xor`, `!`/`not` are each one operator under two spellings -- the word
# is an alias for the symbol, the same node either way. The bitwise `&`/`^`/`|`
# are a separate family, integers only (see bytes.ref); they are NOT logical
# and do not appear here on booleans. Every line must hold.

data a : boolean;
data b : boolean;

# ── word aliases equal their symbols, operand for operand ────────────────────
G((a and b) == (a && b));
G((a or  b) == (a || b));
G((a xor b) == (a ^^ b));
G((not a)   == (!a));

# ── logical xor: true iff the operands differ; no `^^^`, and it is the only
#    logical xor (the bitwise `^` does not take booleans) ─────────────────────
G((a ^^ b) == (a != b));
G((a xor b) == ((a || b) && not (a && b)));

# ── the words compose and nest like the symbols ──────────────────────────────
G((a and not b) == (a && !b));
G((not (a or b)) == (!a && !b));            # de Morgan
G(a xor b xor a == b);                      # xor is associative; a cancels

# ── mixing spellings in one expression is fine -- same nodes ─────────────────
G((a and b or not a) == (a && b || !a));

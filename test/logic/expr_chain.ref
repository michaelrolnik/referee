# Computed props defined in terms of *other* computed props.
#
# Uses expr_data.csv (4 real rows, a/b boolean).
#
# This is the fixture for the ordering contract of __prepare__: `y` reads `x`
# one state into the future, so `x` must already be materialised across the
# whole trace before `y` is evaluated anywhere.  Filling props state-by-state
# (all props at state 0, then all props at state 1, ...) would read x[i+1]
# before it was written and silently produce garbage for y.
#
# Each identity is also restated in fully-expanded form, so a wrong value that
# happened to be self-consistent between the stored prop and its re-evaluation
# would still be caught.

data    a:  boolean;
data    b:  boolean;

# Past-operator base: x depends only on CSV-backed props.
data    x = Ss(a, b);
G(x == Ss(a, b));

# Future dependency on a computed prop -- the ordering-sensitive case.
data    y = Xs(x);
G(y == Xs(x));
G(y == Xs(Ss(a, b)));

# Past dependency on a computed prop that itself has a future dependency.
data    z = Ys(y);
G(z == Ys(y));
G(z == Ys(Xs(Ss(a, b))));

# Non-temporal composition over a chain member, to pin the point-wise path too.
data    w = z && !x;
G(w == (z && !x));

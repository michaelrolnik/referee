# Discrete accumulation over records, selected by a condition.
#
#   Itg(c, v)  integrates v over *time* while c holds        (existing)
#   Sum(c, v)  totals v over the *records* where c holds     (new)
#   Cnt(c)     counts the records where c holds              (new)
#
# All three share a shape: a condition selects, states where it fails are
# skipped, and the walk is bounded only by the [lo:hi] window. What differs is
# the weight each contributing state carries -- Itg weights by duration, which
# is right for "how long was the valve open" and wrong for "how many bytes were
# in this message". A protocol's message-length and packet-count limits are
# discrete, and were not expressible before.
#
# Trace: an MCTP-shaped pair of messages.
#   t=0    SOM len=10 | 1000 MID 20 | 2000 MID 30 | 3000 MID 40 | 4000 EOM 5
#   t=5000 SOM len=7  | 6000 MID  8 | 7000 EOM  1

type K   : enum { SOM, MID, EOM };
data k   : K;
data len : integer;

# ── Over the whole remaining trace ───────────────────────────────────────────
Cnt(true)       == 8;                       # every record
Cnt(k.SOM)      == 2;                       # two messages
Cnt(k.EOM)      == 2;
Cnt(k.MID)      == 4;                       # three in the first, one in the second
Sum(true, len)  == 121;                     # 10+20+30+40+5 + 7+8+1
Sum(k.MID, len) == 98;                      # 20+30+40 + 8

# ── Unselected states are skipped, not stopped at ────────────────────────────
# k.MID is false at t=0 and again at t=4000, and the walk carries on through
# both. A stopping rule would have given 0 here, not 4.
Cnt(k.MID)      == 4;

# ── Time-bounded, reusing the existing [lo:hi] ───────────────────────────────
Cnt[0:2500](true)         == 3;             # t = 0, 1000, 2000
Cnt[0:2500](k.MID)        == 2;
Sum[0:2500](true, len)    == 60;            # 10 + 20 + 30
Sum[1500:2500](true, len) == 30;            # the window's lower end clips too

# ── Cnt is Sum over ones, so they agree ──────────────────────────────────────
G(Cnt(k.MID) == Sum(k.MID, 1));
G(Cnt[0:3000](k.MID) == Sum[0:3000](k.MID, 1));

# ── Protocol limits, bounded by the window rather than by the message ────────
# A per-message bound needs a window wide enough to cover one message and no
# more; the condition selects states, it does not delimit them.
G(k.SOM => Cnt[0:5000](k.MID) <= 8);        # at most 8 packets per message
G(k.SOM => Sum[0:5000](true, len) <= 4096); # and at most 4096 bytes

# ── Boundary cases, for the linear rewrite ───────────────────────────────────
# `Sum`/`Cnt`/`Itg` walk forward from each state, so under a temporal operator
# they are O(N²) -- see docs/accumulator-cost.md. The fix is the backward
# recurrence the until/release family already uses:
#
#     Sum(c, v)[s]  =  (c[s] ? v[s] : 0) + Sum(c, v)[s+1]
#
# A recurrence is got wrong at its *ends*, not in the middle, and the cases
# below are the ends. They hold for the current forward walk, so they pin the
# behaviour a rewrite has to preserve rather than describing a hoped-for one.

# The last state: the suffix is just itself, so the seed of the recurrence.
G(k.EOM && __time__ == 7000 => Cnt(true) == 1);
G(__time__ == 7000 => Sum(true, len) == 1);
G(__time__ == 7000 => Cnt(false) == 0);

# The first state: the whole trace, so the fold must have run to completion.
G(__time__ == 0 => Cnt(true) == 8);
G(__time__ == 0 => Sum(true, len) == 121);

# One state in: the fold at s must equal the fold at s+1 plus this state's own
# contribution. This is the recurrence itself, asserted directly.
G(__time__ == 6000 => Cnt(true) == 2);
G(__time__ == 6000 => Sum(true, len) == 9);      # 8 + 1

# A condition false everywhere folds to the identity, not to a stale value.
G(Cnt(false) == 0);
G(Sum(false, len) == 0);

# A condition true everywhere counts every remaining state, including this one.
G(__time__ == 5000 => Cnt(true) == 3);

# A window that closes before the next state: the accumulation is this state
# alone, which is where an off-by-one in the bound shows up.
G(__time__ == 0 => Cnt[0:1](true) == 1);
G(__time__ == 0 => Sum[0:1](true, len) == 10);

# A window of zero width accumulates nothing at all.
G(Cnt[0:0](true) == 0);
G(Sum[0:0](true, len) == 0);

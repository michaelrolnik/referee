# External functions: a `func` declaration, and calls to it.
#
# The implementation is test/plugins/helpers.c, compiled to a .so that referee
# finds on the -L search path. The C symbol carries a `referee_` prefix, so
# `func triple` binds to `referee_triple`.
#
# What this covers: each primitive across the boundary, a call nested inside
# another, a call in a computed signal, and a call inside a temporal loop --
# calls are ordinary expressions and may appear anywhere one may.

func triple    : (integer) -> integer;
func half      : (number)  -> number;
func is_even   : (integer) -> boolean;
func crc8_step : (byte, byte) -> byte;

# An array parameter is written unsized: the extent travels in the descriptor
# built at the call, so one declaration serves any trace shape.
func crc8      : (byte[], integer) -> byte;
func capacity  : (byte[]) -> integer;
func first     : (byte[]) -> integer;

# A struct crosses by const pointer; an enum by value, as its one-byte storage.
type Point : struct { x : integer; y : integer; };
type Kind  : enum { FIRST, SECOND };
func sum2     : (Point) -> integer;
func is_first : (Kind) -> boolean;

data i : integer;
data r : number;
data b   : byte;
data len : byte;
data pkt : byte[];
data pt  : Point;
data k   : Kind;

# One per primitive result type.
G(triple(i)  == i * 3);
G(half(r)    == r / 2.0);
G(is_even(i) <=> i % 2 == 0);

# `byte` is a storage width, not a value kind: the argument is narrowed at the
# call and the result widened back, so this compares against an integer.
G(crc8_step(0, 0) == 0);
G(crc8_step(0, b) >= 0);
G(crc8_step(0, b) <= 255);

# A call is an expression: it nests, and it composes with everything else.
G(triple(triple(i)) == i * 9);
G(triple(i) + triple(i) == triple(i) * 2);
G(is_even(triple(i)) <=> is_even(i));

# In a computed signal -- the idiom, because __prepare__ evaluates it once per
# state rather than once per state per enclosing loop iteration.
data t3 = triple(i);
G(t3 == i * 3);

# Inside a temporal loop, which is permitted and merely more expensive.
Sum(true, triple(i)) == 3 * Sum(true, i);
Cnt(is_even(i)) == 1;

# ── Arrays: the motivating case ──────────────────────────────────────────────
# A CRC is the reason external functions exist. REF has no fold over an array
# and no function abstraction, so the only spelling in the language itself is
# the fully unrolled polynomial -- eight shift/xor steps per octet, per octet.

# The descriptor's count is the extent, and agrees with REF's own view of it.
G(capacity(pkt) == 4);
G(capacity(pkt) == pkt.count);

# The data pointer addresses the array's storage, not a copy of it.
G(first(pkt) == pkt[0]);

# Because the count is real, the callee can refuse a length it was handed.
G(crc8(pkt, 99) == 0xFF);
G(crc8(pkt, 0) == 0);

# Values checked against an independent implementation, not against itself.
G(__time__ == 0    => crc8(pkt, 3) == 0xC1);    # DE AD BE
G(__time__ == 1000 => crc8(pkt, 4) == 0xE3);    # 01 02 03 04

# The PEC idiom: a computed signal, evaluated once per state.
data pec = crc8(pkt, len);
G(pec >= 0 && pec <= 255);

# ── Composites as arguments ──────────────────────────────────────────────────
# Both of these compiled before they worked. A struct-valued expression is
# never loaded, so referee passed the pointer to a function declared taking the
# struct by value; an enum argument passed a pointer where a byte was wanted.
# Neither was an error -- the callee read whatever the pointer happened to
# alias, so the answer was wrong rather than refused.
G(sum2(pt) == pt.x + pt.y);
G(is_first(k) <=> k.FIRST);

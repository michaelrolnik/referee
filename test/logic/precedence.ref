# Operator precedence, pinned.
#
# The grammar's binding order is not C's, and the README documents it as such.
# These requirements state the groupings the documentation claims, so the two
# cannot drift apart: if the grammar is ever changed to conventional
# precedence, this file fails and the prose has to be revisited with it.

type State : enum { ON, OFF };

data    a       : boolean;
data    b       : boolean;
data    c       : boolean;
data    lock    : State;

# `+`/`-` bind tighter than `*`/`/`/`%`, so this groups as (2 + 3) * 4.
(2 + 3 * 4) == 20;
(10 - 2 * 5) == 40;

# `||` binds tighter than `&&`, so this groups as (a || b) && c.
# With a=true, b=false, c=false: (true || false) && false = false,
# whereas C's grouping a || (b && c) would give true.
(a || b && c) == false;

# The logical operators bind tighter than the comparisons. Written without
# parentheses `a && 1 == 1` would group as `(a && 1) == 1` and fail to type
# check, so the comparison has to be parenthesised to mean what it looks like.
a && (1 == 1);

# Enum members are reached through the signal, never through the type.
lock.ON;

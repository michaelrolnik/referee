# Operator precedence, pinned.
#
# REF follows C++ / Kotlin: multiplicative, then additive, then relational,
# then equality, then ^, then &&, then ||. Implication and biconditional have
# no C++ equivalent and sit where logic conventionally puts them -- looser than
# || and tighter than the conditional.
#
# These requirements state the groupings, so the grammar and the precedence
# table in the README cannot drift apart.

type State : enum { ON, OFF };

data    a       : boolean;
data    b       : boolean;
data    c       : boolean;
data    lock    : State;

# ── Arithmetic ───────────────────────────────────────────────────────────────
# `*` binds tighter than `+`, so this groups as 2 + (3 * 4).
(2 + 3 * 4) == 14;
(10 - 2 * 5) == 0;
(1 + 8 / 4) == 3;
(7 - 6 % 4) == 5;

# ── Logical ──────────────────────────────────────────────────────────────────
# `&&` binds tighter than `||`, so this groups as a || (b && c).
# With a=true, b=false, c=false that is true; the other grouping gives false.
(a || b && c) == true;

# ── Comparison against logical ───────────────────────────────────────────────
# Comparisons bind tighter than `&&` and `||`, so these need no parentheses.
a && 1 == 1;
a || 1 != 1;
1 < 2 && 3 > 2;
a && 2 + 3 * 4 == 14;

# ── Implication is looser than || ────────────────────────────────────────────
# Reads as (a || b) => (a || b), which holds whatever the operands are.
a || b => a || b;

# ── Unary binds tightest ─────────────────────────────────────────────────────
(-3 + 5) == 2;

# Enum members are reached through the signal, never through the type.
lock.ON;
